{
  "id": "contract-analysis",
  "name": "Contract Analysis",
  "description": "Extract clauses and legal terms from agreements.",
  "category": "legal",
  "preset": "extraction-focused",
  "chunk_size": 2000,
  "overlap": 200,
  "mode": "semantic-lite",
  "fields": [
    { "name": "contract_title", "type": "string" },
    { "name": "contract_type", "type": "string" },
    { "name": "parties", "type": "array" },
    { "name": "effective_date", "type": "date" },
    { "name": "expiration_date", "type": "date" },
    { "name": "term_length", "type": "string" },
    { "name": "renewal_terms", "type": "string" },
    { "name": "termination_clause", "type": "string" },
    { "name": "liability_limitation", "type": "string" },
    { "name": "dispute_resolution", "type": "string" },
    { "name": "governing_law", "type": "string" },
    { "name": "key_obligations", "type": "array" },
    { "name": "payment_terms", "type": "string" },
    { "name": "confidentiality_clause", "type": "string" },
    { "name": "signatures_present", "type": "boolean" }
  ]
}
